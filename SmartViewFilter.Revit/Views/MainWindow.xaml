<Window x:Class="SmartViewFilter.Revit.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:SmartViewFilter.Revit.Converters"
        Title="Smart View Filter 2.0"
        Width="1080"
        Height="760"
        MinWidth="960"
        MinHeight="640"
        WindowStartupLocation="CenterOwner"
        Background="#F4F6F8">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1F2933" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="4" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#1D4ED8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D9E2EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="14" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="220" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PanelBorder}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Smart View Filter 2.0" FontSize="24" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding StatusText}" Foreground="#52616B" Margin="0,4,0,0" />
                    <TextBlock Text="{Binding ValidationText}" Foreground="#B42318" Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding SourceSummaryText}" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="#52616B" />
                    <Button Content="Privacy" Command="{Binding OpenPrivacyPolicyCommand}" MinWidth="80" />
                    <Button Content="Read Selection" Style="{StaticResource PrimaryButton}" Command="{Binding ReadSelectionCommand}" MinWidth="150" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="1.1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Source Scope" FontSize="16" FontWeight="SemiBold" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Expand" Command="{Binding ExpandAllCommand}" />
                            <Button Content="Collapse" Command="{Binding CollapseAllCommand}" />
                            <Button Content="Select All" Command="{Binding SelectAllScopeCommand}" />
                            <Button Content="Clear" Command="{Binding ClearScopeCommand}" />
                        </StackPanel>
                    </Grid>

                    <TextBox Grid.Row="1"
                             Text="{Binding ScopeSearchText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,10,0,10"
                             Height="32"
                             VerticalContentAlignment="Center"
                             Padding="8,0"
                             ToolTip="Search categories, families, or types" />

                    <Grid Grid.Row="2">
                    <TextBlock Text="No source loaded yet. Select elements in Revit and click Read Selection."
                                   TextWrapping="Wrap"
                                   Foreground="#697586"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Width="360"
                                   TextAlignment="Center"
                                   Visibility="{Binding HasSource, Converter={StaticResource InverseBoolToVisibility}}" />

                        <TreeView ItemsSource="{Binding ScopeNodes}"
                                  Visibility="{Binding HasSource, Converter={StaticResource BoolToVisibility}}">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="{x:Type TreeViewItem}">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                    <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource BoolToVisibility}}" />
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Content="{Binding DisplayName}"
                                              Margin="0,3" />
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Saved Configurations" FontSize="16" FontWeight="SemiBold" />
                    <TextBox Grid.Row="1"
                             Text="{Binding NewConfigurationName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,10,0,10"
                             Height="32"
                             VerticalContentAlignment="Center"
                             Padding="8,0"
                             ToolTip="Configuration name" />

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding SavedConfigurations}"
                             SelectedItem="{Binding SelectedConfiguration}"
                             DisplayMemberPath="Name"
                             BorderBrush="#D9E2EC" />

                    <UniformGrid Grid.Row="3" Columns="3" Margin="0,10,0,0">
                        <Button Content="Save" Command="{Binding SaveConfigurationCommand}" />
                        <Button Content="Load" Command="{Binding LoadConfigurationCommand}" />
                        <Button Content="Delete" Command="{Binding DeleteConfigurationCommand}" />
                    </UniformGrid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource PanelBorder}" Margin="0,12,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Filter Rules" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="Rules are evaluated from top to bottom. Mixed AND / OR logic is supported." Foreground="#697586" Margin="0,3,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <RadioButton Content="Selected source only" IsChecked="{Binding SelectedSourceOnly}" GroupName="Domain" VerticalAlignment="Center" Margin="0,0,12,0" />
                        <RadioButton Content="Project elements" IsChecked="{Binding ProjectElements}" GroupName="Domain" VerticalAlignment="Center" Margin="0,0,18,0" />
                        <CheckBox Content="Live preview" IsChecked="{Binding LivePreviewEnabled}" VerticalAlignment="Center" Margin="0,0,12,0" />
                        <CheckBox Content="Limit to active view" IsChecked="{Binding LimitToActiveView}" VerticalAlignment="Center" Margin="0,0,12,0" />
                        <CheckBox Content="Include element types" IsChecked="{Binding IncludeElementTypes}" VerticalAlignment="Center" />
                        <Button Content="Add Rule" Command="{Binding AddRuleCommand}" Margin="12,0,4,0" />
                        <Button Content="Remove Last" Command="{Binding RemoveLastRuleCommand}" />
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                    <ItemsControl ItemsSource="{Binding Rules}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#D9E2EC" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,8" Background="#FBFCFE">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="92" />
                                                <ColumnDefinition Width="1.35*" />
                                                <ColumnDefinition Width="1.2*" />
                                                <ColumnDefinition Width="145" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="110" />
                                            </Grid.ColumnDefinitions>

                                            <Grid Grid.Column="0">
                                                <TextBlock Text="Start" VerticalAlignment="Center" Visibility="{Binding IsFirst, Converter={StaticResource BoolToVisibility}}" Foreground="#697586" />
                                            <ComboBox ItemsSource="{Binding AvailableLogicOptions}"
                                                      SelectedItem="{Binding LogicWithPrevious}"
                                                      Visibility="{Binding IsFirst, Converter={StaticResource InverseBoolToVisibility}}"
                                                      Height="30" />
                                            </Grid>

                                            <TextBox Grid.Column="1"
                                                     Text="{Binding ParameterSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                     Height="30"
                                                     VerticalContentAlignment="Center"
                                                     Padding="8,0"
                                                     Margin="6,0"
                                                     ToolTip="Search parameter names" />

                                            <ComboBox Grid.Column="2"
                                                  ItemsSource="{Binding ParameterOptions}"
                                                  SelectedItem="{Binding ParameterName}"
                                                  IsEditable="True"
                                                  Height="30"
                                                  Margin="6,0" />

                                        <ComboBox Grid.Column="3"
                                                  ItemsSource="{Binding AvailableOperators}"
                                                  SelectedItem="{Binding Operator}"
                                                  Height="30"
                                                  Margin="6,0" />

                                        <TextBox Grid.Column="4"
                                                 Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="30"
                                                 VerticalContentAlignment="Center"
                                                 Padding="8,0"
                                                 Margin="6,0" />

                                        <CheckBox Grid.Column="5"
                                                  Content="Match case"
                                                  IsChecked="{Binding MatchCase}"
                                                  VerticalAlignment="Center"
                                                  Margin="8,0,0,0" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource PanelBorder}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding MatchCountText}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Apply" Command="{Binding ApplyCommand}" Style="{StaticResource PrimaryButton}" MinWidth="110" />
                    <Button Content="Select" Command="{Binding SelectCommand}" MinWidth="95" />
                    <Button Content="Isolate" Command="{Binding IsolateCommand}" MinWidth="95" />
                    <Button Content="Clear" Command="{Binding ClearCommand}" MinWidth="95" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
